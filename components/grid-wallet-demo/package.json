    "motion": "^12.33.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.97.3",
    "torph": "^0.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3"
  }
