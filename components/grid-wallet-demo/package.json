{
  "name": "grid-wallet-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive Grid Global Accounts wallet demo, embedded in the Grid docs.",
  "scripts": {
    "dev": "next dev -p 4000",
    "dev:apple": "next dev -p 4000 -H grid-wallet-demo-local.lightspark.com --experimental-https --experimental-https-key ./certs/apple-local-key.pem --experimental-https-cert ./certs/apple-local.pem",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "export-sf-symbols": "node scripts/export-sf-symbols.mjs --sync-paths",
    "fetch:flags": "node scripts/fetch-flags.mjs",
    "gen:bank-fields": "node scripts/generate-bank-fields.mjs",
    "verify:bank-fields": "node scripts/generate-bank-fields.mjs && git diff --exit-code -- src/data/bankAccountFields.generated.ts",
    "verify:bank-data": "tsx scripts/verify-bank-data.ts",
    "verify:bank": "npm run verify:bank-fields && npm run verify:bank-data"
  },
  "dependencies": {
    "@central-icons-react/round-filled-radius-0-stroke-2": "^1.1.267",
    "@central-icons-react/round-outlined-radius-0-stroke-2": "^1.1.267",
    "@central-icons-react/round-outlined-radius-1-stroke-1.5": "^1.1.265",
    "@central-icons-react/round-outlined-radius-3-stroke-1.5": "^1.1.135",
    "@lightsparkdev/origin": "^0.13.4",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "clsx": "^2.1.1",
    "motion": "^12.33.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.97.3",
    "torph": "^0.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
